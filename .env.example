# NextAuth — MUST match ContextTube for cross-domain SSO
NEXTAUTH_URL=https://contextcloud.studio
NEXTAUTH_SECRET=same-as-contextube

# Postgres — same instance as ContextTube
DATABASE_URL=postgresql://user:password@host:5432/contextube

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In (https://developer.apple.com/account/resources/identifiers)
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_TEAM_ID=
APPLE_PRIVATE_KEY=
